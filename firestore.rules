rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-all Safeguard
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // UserProfile Validation Helper
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName'])
        && data.uid == request.auth.uid
        && data.displayName is string
        && data.displayName.size() <= 100
        && (!data.keys().contains('theme') || (data.theme is string && data.theme.size() <= 50))
        && (!data.keys().contains('wallpaper') || (data.wallpaper is string && data.wallpaper.size() <= 200))
        && (!data.keys().contains('aiModel') || (data.aiModel is string && data.aiModel.size() <= 50))
        && (!data.keys().contains('voiceName') || (data.voiceName is string && data.voiceName.size() <= 50))
        && (!data.keys().contains('language') || (data.language is string && data.language.size() <= 20))
        && (!data.keys().contains('photoUrl') || (data.photoUrl is string && data.photoUrl.size() <= 1000));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // ChatSession Validation Helper
    function isValidChatSession(data) {
      return data.keys().hasAll(['id', 'userId', 'messages', 'updatedAt'])
        && data.id is string
        && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.messages is list
        && data.messages.size() <= 1000;
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidChatSession(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidChatSession(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
